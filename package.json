{
  "name": "prisma-enum-list-generator",
  "version": "5.1.0",
  "description": "Generates const enum value lists for Prisma enums",
  "keywords": [
    "prisma",
    "generator",
    "enum",
    "list",
    "typescript"
  ],
  "homepage": "https://github.com/sohibe/prisma-enum-list-generator",
  "bugs": "https://github.com/sohibe/prisma-enum-list-generator/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sohibe/prisma-enum-list-generator.git"
  },
  "license": "MIT",
  "author": "Arthur Fiorette <npm@arthur.place>",
  "type": "commonjs",
  "main": "./index.js",
  "bin": {
    "prisma-enum-list-generator": "index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint-ci": "biome ci .",
    "lint-fix": "biome check --write --unsafe .",
    "prepare": "husky",
    "test-unit": "tsx --test test/unit/**/*.test.ts"
  },
  "dependencies": {
    "@prisma/generator-helper": "^7.8.0"
  },
  "devDependencies": {
    "@arthurfiorette/biomejs-config": "^2.0.1",
    "@biomejs/biome": "^2.4.13",
    "@prisma/dmmf": "^7.8.0",
    "@prisma/generator": "^7.8.0",
    "@types/node": "^24.12.2",
    "husky": "^9.1.7",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "@prisma/client": "^7.8.0",
    "prisma": "^7.8.0"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=14.0"
  }
}
